# ─── Trail API ─────────────────────────────────────────────────────────────────
# Your Trail API key — find it in Trail: Settings → Integrations
TRAIL_API_KEY=your_trail_api_key_here

# Trail API base URL — only change if Trail updates their API version
TRAIL_API_BASE_URL=https://web.trailapp.com/api/v1

# ─── Quick Links ────────────────────────────────────────────────────────────────
# Paste the full URL you want each card to open when clicked

NOTION_URL=https://www.notion.so/your-workspace

GOOGLE_DRIVE_URL=https://drive.google.com/drive/folders/your-folder-id

HR_PAYROLL_URL=https://your-hr-system.com

# Trail web app direct link (the UI, not the API)
TRAIL_APP_URL=https://web.trailapp.com

# ─── Dashboard ──────────────────────────────────────────────────────────────────
# Title shown in the header
DASHBOARD_TITLE=Operations Toolbox
